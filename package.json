{
  "name": "opencroc",
  "version": "1.8.6",
  "description": "AI-native project intelligence platform — universal scanner, knowledge graph, risk analysis, multi-perspective reports, and E2E testing",
  "keywords": [
    "project-intelligence",
    "knowledge-graph",
    "code-analysis",
    "risk-detection",
    "e2e",
    "testing",
    "ai",
    "playwright",
    "test-generation",
    "self-healing",
    "source-aware",
    "multi-language",
    "scanner"
  ],
  "homepage": "https://opencroc.com",
  "bugs": {
    "url": "https://github.com/opencroc/opencroc/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opencroc/opencroc.git"
  },
  "license": "MIT",
  "author": "OpenCroc Contributors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "opencroc": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run web:build && tsup",
    "dev": "concurrently -k -n server,web -c cyan,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch src/cli/index.ts serve --host 0.0.0.0 --port 8765 --no-open",
    "dev:web": "vite --config src/web/vite.config.ts --host 0.0.0.0 --port 5173",
    "build:watch": "tsup --watch",
    "serve:dev": "tsx src/cli/index.ts serve",
    "serve": "node dist/cli/index.js serve",
    "web:build": "vite build --config src/web/vite.config.ts",
    "web:dev": "vite --config src/web/vite.config.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run --config vitest.config.ts",
    "test:stable": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.0",
    "fastify": "^5.8.2",
    "glob": "^10.3.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.2",
    "ts-morph": "^22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^5.4.21",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": false
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
