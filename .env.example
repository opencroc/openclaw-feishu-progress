# Feishu / Lark app credentials
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=sec_xxx

# Optional: provide a fixed tenant token instead of app id + secret
# FEISHU_TENANT_ACCESS_TOKEN=t-xxx

# Public base URL used in task detail links sent back to Feishu
OPENCLAW_FEISHU_PROGRESS_BASE_TASK_URL=http://127.0.0.1:8765
OPENCROC_DEV_API_TARGET=http://127.0.0.1:8765

# Optional: Feishu webhook verification / signature settings
# FEISHU_WEBHOOK_VERIFICATION_TOKEN=verify_xxx
# FEISHU_WEBHOOK_ENCRYPT_KEY=encrypt_xxx
# FEISHU_WEBHOOK_MAX_SKEW_SECONDS=300
# FEISHU_WEBHOOK_DEDUP_TTL_SECONDS=600

# Optional: OpenClaw relay HMAC settings
# OPENCLAW_RELAY_SECRET=relay_xxx
# OPENCLAW_RELAY_MAX_SKEW_SECONDS=300
# OPENCLAW_RELAY_NONCE_TTL_SECONDS=600

# Optional: outbound retry / progress throttling
# FEISHU_DELIVERY_MAX_RETRIES=2
# FEISHU_DELIVERY_RETRY_BASE_MS=300
# FEISHU_DELIVERY_RETRY_MAX_MS=5000
# FEISHU_PROGRESS_THROTTLE_PERCENT=10

# Backward-compatible alias still read by the config
# OPENCROC_BASE_TASK_URL=http://127.0.0.1:8765
